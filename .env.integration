# Integration Tests env (real Postgres + real Better Auth + real Server Actions)
# Loaded by env.integration.setup.ts and vitest.integration.config.js.
#
# This file mirrors .env.test for shared values, but integration tests:
# - hit a real running dev DB (docker compose -f docker-compose.dev.yaml up -d)
# - call real Better Auth endpoints to obtain a session cookie
# - exercise the full Next.js Server Action / API Route surface
#
# IMPORTANT: do NOT point this at a production database.

# Database
DATABASE_URL="postgresql://nextcrm:nextcrm_dev@localhost:5432/nextcrm"
DB_HOST=localhost
DB_PORT=5432
DB_USER=nextcrm
DB_PASSWORD=nextcrm_dev
DB_NAME=nextcrm

# Better Auth
BETTER_AUTH_SECRET="dev-secret-do-not-use-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (optional for dev)
GOOGLE_ID=""
GOOGLE_SECRET=""

# Email Service (optional for dev)
RESEND_API_KEY=""

# AI (optional for dev)
OPENAI_API_KEY=""

# Firecrawl (optional for dev)
FIRECRAWL_API_KEY=""

# E2B (optional for dev)
E2B_API_KEY=""

# MinIO
NEXT_PUBLIC_MINIO_ENDPOINT="http://localhost:9000"
MINIO_ENDPOINT="http://localhost:9000"
MINIO_PORT="9000"
MINIO_BUCKET="nextcrm"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="nextcrm"
MINIO_SECRET_KEY="minio_dev_password"

# Inngest
INNGEST_DEV="1"
INNGEST_ID="nextcrm"
INNGEST_APP_NAME="NextCRM"
INNGEST_EVENT_KEY="local"
INNGEST_SIGNING_KEY=""
INNGEST_BASE_URL="http://localhost:8288"

# App
NEXT_PUBLIC_APP_NAME="NextCRM"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dev admin user (created by prisma db seed)
TEST_USER_EMAIL="admin@example.com"

# Cron secret
CRON_SECRET="dev-cron-secret"

# Email encryption
EMAIL_ENCRYPTION_KEY="dev-email-encryption-key-64-chars-long-here-1234567890abcdef"

# Resend (optional for dev)
RESEND_WEBHOOK_SECRET=""
RESEND_FROM_EMAIL=""

# Server Actions rely on EMAIL_FROM being defined even when no real mail is sent.
EMAIL_FROM="no-reply@nextcrm.test"

# Integration-suite knobs (read by tests/integration/helpers/*)
# Unique suffix for fixture isolation across local runs.
INTEGRATION_SUFFIX=""
# When true, helper auth() performs a real HTTP sign-in OTP dance against
# a running dev server on BETTER_AUTH_URL. Required for end-to-end coverage.
INTEGRATION_USE_HTTP_AUTH="true"
# When true, prisma/seeds/fixtures.ts seeds the CRM base fixtures
# (account, contact, lead, opportunity, contract, activity) per §3.4.2 of
# the integration test design. Required for PIAC..PIACT suites.
INTEGRATION_FIXTURES="true"
