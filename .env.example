# =============================================================
# NextCRM Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For Docker deployments:
#   cp .env.example .env
#   nano .env  # set ADMIN_EMAIL and optional API keys
#   docker compose up -d
#
# For local development (without Docker):
#   cp .env.example .env
#   nano .env  # set DATABASE_URL to your local Postgres
#   pnpm install && pnpm prisma generate && pnpm prisma migrate deploy
#   pnpm prisma db seed && pnpm run dev
#
# .env is in .gitignore — your secrets stay local.
# =============================================================

# =============================================================
# REQUIRED: Initial admin account
# =============================================================
# This email becomes the admin user created by the seed script
# on first start. The app uses passwordless Email OTP to log in,
# so you MUST set this to a real email you control AND configure
# an email provider (RESEND_API_KEY below) so OTP codes can be
# delivered. Without an email provider, you can still read the
# OTP from the database directly while testing.
#
# Only used on first run (when no users exist in the database).
# Changing it later has no effect — create new admins from the
# Admin panel instead.
# =============================================================
ADMIN_EMAIL=you@example.com

# =============================================================
# REQUIRED: PostgreSQL Database
# =============================================================
# Requires PostgreSQL 17+ with the pgvector extension enabled.
# For Docker: values come from POSTGRES_USER/PASSWORD/DB below.
# For local: set DATABASE_URL to your local Postgres instance.
# =============================================================
DATABASE_URL="postgresql://nextcrm:changeme@localhost:5432/nextcrm?schema=public"

# Internal DB credentials (used by Docker Compose and app container)
POSTGRES_USER=nextcrm
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nextcrm

DB_HOST=localhost
DB_PORT=5432
DB_USER=nextcrm
DB_PASSWORD=changeme
DB_NAME=nextcrm

# =============================================================
# Auth
# =============================================================
# Auto-generated on first start if not set.
# Set explicitly for stable sessions across container restarts.
# Generate with: openssl rand -base64 32
# =============================================================
BETTER_AUTH_SECRET="your-secret-here"
BETTER_AUTH_URL=http://localhost:3000

# =============================================================
# Google OAuth (optional)
# =============================================================
GOOGLE_ID=
GOOGLE_SECRET=

# =============================================================
# OpenAI (optional, for AI features)
# =============================================================
OPENAI_API_KEY=

# =============================================================
# Email Sending via Resend (recommended)
# =============================================================
# Required so the admin (ADMIN_EMAIL above) can actually receive
# the login OTP. Without this, OTP codes go nowhere and you'll
# need to read them from the database manually.
# =============================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# =============================================================
# SMTP / IMAP (optional, for email client)
# =============================================================
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
IMAP_HOST=
IMAP_PORT=
IMAP_USER=
IMAP_PASSWORD=

# =============================================================
# Firecrawl (optional, for contact enrichment)
# =============================================================
FIRECRAWL_API_KEY=

# =============================================================
# E2B (optional, for agent enrichment)
# =============================================================
E2B_API_KEY=

# =============================================================
# Rossum (optional, for invoice parsing)
# =============================================================
ROSSUM_USERNAME=
ROSSUM_PASSWORD=

# =============================================================
# Internal cron job endpoints
# =============================================================
CRON_SECRET=

# =============================================================
# Email feature — generate with: openssl rand -hex 32
# =============================================================
EMAIL_ENCRYPTION_KEY=

# =============================================================
# Campaigns — Resend webhook signing secret
# =============================================================
RESEND_WEBHOOK_SECRET=

# =============================================================
# MinIO Object Storage
# =============================================================
# For Docker: values come from MINIO_ROOT_USER/PASSWORD above.
# For local: set to your local MinIO instance.
# =============================================================
NEXT_PUBLIC_MINIO_ENDPOINT=http://localhost:9000
MINIO_ENDPOINT=http://localhost:9000
MINIO_PORT=9000
MINIO_BUCKET=nextcrm
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=nextcrm
MINIO_SECRET_KEY=changeme

# =============================================================
# Inngest (background jobs)
# =============================================================
INNGEST_DEV=1
INNGEST_ID=nextcrm
INNGEST_APP_NAME=NextCRM
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=
INNGEST_BASE_URL=http://localhost:8288

# =============================================================
# App
# =============================================================
NEXT_PUBLIC_APP_NAME=NextCRM
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================
# Dev admin email (created by prisma db seed)
# =============================================================
TEST_USER_EMAIL=admin@example.com

# =============================================================
# Email from address (required for Server Actions)
# =============================================================
EMAIL_FROM=no-reply@nextcrm.test
