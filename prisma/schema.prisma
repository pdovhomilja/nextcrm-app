model crm_Targets {
  id               String    @id @default(uuid()) @db.Uuid
  first_name       String?
  last_name        String
  email            String?
  mobile_phone     String?
  office_phone     String?
  company          String?
  company_website  String?
  personal_website String?
  position         String?
  social_x         String?
  social_linkedin  String?
  social_instagram String?
  social_facebook  String?
  status           Boolean   @default(true)
  tags             String[]
  notes            String[]
  created_by       String?   @db.Uuid
  created_on       DateTime? @default(now())
  updatedAt        DateTime? @updatedAt
  updatedBy        String?   @db.Uuid

  // Extended contact fields
  personal_email   String?
  company_email    String?
  company_phone    String?
  city             String?
  country          String?
  industry         String?
  employees        String?
  description      String?

  // Conversion tracking
  converted_at         DateTime?
  converted_account_id String?   @db.Uuid
  converted_contact_id String?   @db.Uuid

  deletedAt        DateTime?
  deletedBy        String?   @db.Uuid

  crate_by_user     Users?                 @relation("created_targets", fields: [created_by], references: [id])
  target_lists      TargetsToTargetLists[]
  enrichments       crm_Target_Enrichment[]
  target_contacts   crm_Target_Contact[]
  campaign_sends    crm_campaign_sends[]
  converted_account crm_Accounts?          @relation("target_converted_account", fields: [converted_account_id], references: [id], onDelete: SetNull)
  converted_contact crm_Contacts?          @relation("target_converted_contact", fields: [converted_contact_id], references: [id], onDelete: SetNull)

  @@index([created_by])
  @@index([status])
  @@index([created_on])
  @@index([converted_account_id])
  @@index([converted_contact_id])
  @@index([deletedAt])
}

model crm_TargetLists {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  status      Boolean   @default(true)
  created_by  String?   @db.Uuid
  created_on  DateTime? @default(now())
  updatedAt   DateTime? @updatedAt
  deletedAt   DateTime?
  deletedBy   String?   @db.Uuid

  crate_by_user  Users?               @relation("created_target_lists", fields: [created_by], references: [id])
  targets        TargetsToTargetLists[]
  campaign_lists CampaignToTargetLists[]

  @@index([created_by])
  @@index([status])
  @@index([deletedAt])
}

model TargetsToTargetLists {
  target_id      String @db.Uuid
  target_list_id String @db.Uuid

  target      crm_Targets     @relation(fields: [target_id], references: [id], onDelete: Cascade)
  target_list crm_TargetLists @relation(fields: [target_list_id], references: [id], onDelete: Cascade)

  @@id([target_id, target_list_id])
  @@index([target_id])
  @@index([target_list_id])
}

