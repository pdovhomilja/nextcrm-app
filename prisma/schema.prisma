// ============================================
// EMAIL FEATURE
// ============================================

model EmailAccount {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  label             String
  imapHost          String
  imapPort          Int
  imapSsl           Boolean   @default(true)
  smtpHost          String
  smtpPort          Int
  smtpSsl           Boolean   @default(true)
  username          String
  passwordEncrypted String
  isActive          Boolean   @default(true)
  sentFolderName    String    @default("Sent")
  lastSyncedAt      DateTime?
  inboxLastUid      Int?
  sentLastUid       Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user   Users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails Email[]

  @@index([userId])
  @@index([isActive])
}

enum EmailFolder {
  INBOX
  SENT
}

model Email {
  id              String      @id @default(uuid()) @db.Uuid
  emailAccountId  String      @db.Uuid
  userId          String      @db.Uuid
  rfcMessageId    String
  imapUid         Int?
  folder          EmailFolder
  subject         String?
  fromName        String?
  fromEmail       String?
  toRecipients    Json        @default("[]")
  ccRecipients    Json        @default("[]")
  bccRecipients   Json        @default("[]")
  bodyText        String?
  bodyHtml        String?
  sentAt          DateTime?
  isRead          Boolean     @default(false)
  isDeleted       Boolean     @default(false)
  updatedAt       DateTime    @updatedAt
  createdAt       DateTime    @default(now())

  account   EmailAccount     @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  user      Users            @relation(fields: [userId], references: [id], onDelete: Cascade)
  embedding EmailEmbedding?
  contacts  EmailsToContacts[]
  accounts  EmailsToAccounts[]

  @@unique([emailAccountId, rfcMessageId])
  @@index([userId])
  @@index([emailAccountId])
  @@index([folder])
  @@index([isDeleted])
  @@index([sentAt])
  @@index([userId, folder, isDeleted, isRead])
}

model EmailEmbedding {
  id          String   @id @default(uuid()) @db.Uuid
  emailId     String   @unique @db.Uuid
  embedding   Unsupported("vector(1536)")
  contentHash String
  embeddedAt  DateTime @default(now())

