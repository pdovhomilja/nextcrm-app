  assigned_contacts    crm_Contacts[]        @relation("assigned_contacts")
  crated_contacts      crm_Contacts[]        @relation("created_contacts")
  apiKeys              ApiKeys[]
  assigned_contracts   crm_Contracts[]
  boards               Boards[]              @relation("assigned_user")
  watching_boards      BoardWatchers[]
  watching_accounts    AccountWatchers[]
  created_targets      crm_Targets[]         @relation("created_targets")
  created_target_lists crm_TargetLists[]     @relation("created_target_lists")
  apiTokens            ApiToken[]
  emailAccounts        EmailAccount[]
  emails               Email[]
  enrichments_triggered          crm_Contact_Enrichment[]  @relation("enrichment_triggered_by")
  target_enrichments_triggered   crm_Target_Enrichment[]   @relation("target_enrichment_triggered_by")
  created_campaigns              crm_campaigns[]           @relation("created_campaigns")
  created_campaign_templates     crm_campaign_templates[]  @relation("created_campaign_templates")
  auditLogs                      crm_AuditLog[]
  created_products               crm_Products[]    @relation("ProductCreatedBy")
  activities_created             crm_Activities[]  @relation("activity_created_by")
  activities_updated             crm_Activities[]  @relation("activity_updated_by")
  report_configs               crm_Report_Config[]   @relation("report_configs")
  report_schedules             crm_Report_Schedule[] @relation("report_schedules")
  sessions                     Session[]
